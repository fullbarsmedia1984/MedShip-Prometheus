{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medicalshipment.local/schemas/ingestion_profile.schema.json",
  "title": "Contract Pricing Ingestion Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_name",
    "profile_version",
    "status",
    "distributor_name",
    "description",
    "applicable_family_ids",
    "workbook_match_rules",
    "sheet_rules",
    "header_rules",
    "data_region_rules",
    "column_mappings",
    "transforms",
    "default_values",
    "validation_rules",
    "exception_rules",
    "notes",
    "created_at",
    "review_status"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "profile_name": { "type": "string", "minLength": 1 },
    "profile_version": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "review_required", "approved", "deprecated"]
    },
    "distributor_name": { "type": "string", "minLength": 1 },
    "distributor_id": { "type": ["string", "null"] },
    "predecessor_profile": { "type": ["string", "null"] },
    "predecessor_profile_version": { "type": ["string", "null"] },
    "applied_decision_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "decision_references": {
      "type": "object",
      "additionalProperties": true
    },
    "description": { "type": "string" },
    "applicable_family_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "workbook_match_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filename_patterns": { "type": "array", "items": { "type": "string" } },
        "sheet_name_patterns": { "type": "array", "items": { "type": "string" } },
        "required_headers": { "type": "array", "items": { "type": "string" } },
        "optional_headers": { "type": "array", "items": { "type": "string" } },
        "forbidden_headers": { "type": "array", "items": { "type": "string" } },
        "minimum_match_score": { "type": "number", "minimum": 0 }
      },
      "required": ["filename_patterns", "minimum_match_score"]
    },
    "sheet_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact_sheet_name": { "type": ["string", "null"] },
        "case_insensitive_sheet_name": { "type": ["string", "null"] },
        "regex_sheet_name": { "type": ["string", "null"] },
        "include_patterns": { "type": "array", "items": { "type": "string" } },
        "exclude_patterns": { "type": "array", "items": { "type": "string" } },
        "include_hidden_sheets": { "type": "boolean" },
        "process_multiple_matching_sheets": { "type": "boolean" }
      },
      "required": ["include_hidden_sheets", "process_multiple_matching_sheets"]
    },
    "header_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact_header_row": { "type": ["integer", "null"], "minimum": 1 },
        "candidate_row_range": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start": { "type": "integer", "minimum": 1 },
            "end": { "type": "integer", "minimum": 1 }
          },
          "required": ["start", "end"]
        },
        "required_header_terms": { "type": "array", "items": { "type": "string" } },
        "optional_header_terms": { "type": "array", "items": { "type": "string" } },
        "multi_row_header": { "type": "boolean" },
        "merged_header_handling": {
          "type": "string",
          "enum": ["error", "use_top_left", "ignore"]
        },
        "normalized_header_matching": { "type": "boolean" },
        "minimum_header_match_score": { "type": "number", "minimum": 0 }
      },
      "required": [
        "required_header_terms",
        "multi_row_header",
        "merged_header_handling",
        "normalized_header_matching",
        "minimum_header_match_score"
      ]
    },
    "data_region_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "explicit_first_data_row": { "type": ["integer", "null"], "minimum": 1 },
        "first_row_after_detected_header": { "type": "boolean" },
        "explicit_last_row": { "type": ["integer", "null"], "minimum": 1 },
        "stop_after_consecutive_blank_required_field_rows": { "type": "integer", "minimum": 1 },
        "maximum_row_limit": { "type": ["integer", "null"], "minimum": 1 },
        "skip_hidden_rows": { "type": "boolean" },
        "include_hidden_rows_with_warning": { "type": "boolean" },
        "skip_subtotal_and_total_rows": { "type": "boolean" },
        "repeated_header_detection": { "type": "boolean" }
      },
      "required": [
        "first_row_after_detected_header",
        "stop_after_consecutive_blank_required_field_rows",
        "skip_hidden_rows",
        "include_hidden_rows_with_warning",
        "skip_subtotal_and_total_rows",
        "repeated_header_detection"
      ]
    },
    "column_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonical_field", "required", "transforms"],
        "properties": {
          "canonical_field": { "type": "string" },
          "source_header": { "type": ["string", "null"] },
          "source_header_aliases": { "type": "array", "items": { "type": "string" } },
          "source_column_letter": { "type": ["string", "null"] },
          "source_column_index": { "type": ["integer", "null"], "minimum": 1 },
          "required": { "type": "boolean" },
          "transforms": { "type": "array", "items": { "type": "string" } },
          "fallback_source_headers": { "type": "array", "items": { "type": "string" } },
          "constant_value": { "type": ["string", "number", "boolean", "null"] },
          "default_value": { "type": ["string", "number", "boolean", "null"] },
          "notes": { "type": "string" }
        }
      }
    },
    "transforms": { "type": "array", "items": { "type": "string" } },
    "default_values": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string", "enum": ["constant", "manifest"] },
          "value": { "type": ["string", "number", "boolean", "null"] },
          "manifest_field": { "type": ["string", "null"] },
          "required": { "type": "boolean" }
        },
        "required": ["source"]
      }
    },
    "validation_rules": {
      "type": "object",
      "additionalProperties": true
    },
    "exception_rules": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": { "type": "string" },
    "created_at": { "type": "string" },
    "reviewed_by": { "type": ["string", "null"] },
    "review_status": {
      "type": "string",
      "enum": ["not_reviewed", "reviewed", "approved", "rejected"]
    }
  }
}
