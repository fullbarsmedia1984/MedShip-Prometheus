{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contract Pricing Business Decisions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_set_version",
    "status",
    "created_at",
    "updated_at",
    "decided_by",
    "profiles",
    "uom_decisions",
    "metadata_policy",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "decision_set_version": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "incomplete", "ready_to_apply", "applied", "superseded"]
    },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "decided_by": { "type": ["string", "null"] },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile_decision" }
    },
    "uom_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/uom_decision" }
    },
    "metadata_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisions", "notes"],
      "properties": {
        "decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/profile_decision" }
        },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "profile_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_name",
        "family_id",
        "decision_id",
        "category",
        "question",
        "candidate_options",
        "selected_option",
        "rationale",
        "evidence_reference",
        "decision_status",
        "decided_by",
        "decided_at"
      ],
      "properties": {
        "profile_name": { "type": "string" },
        "family_id": { "type": "string" },
        "decision_id": { "type": "string" },
        "category": {
          "type": "string",
          "enum": [
            "pricing_basis",
            "item_identifier",
            "price_uom",
            "base_uom",
            "contract_metadata",
            "effective_date_source",
            "profile_variant",
            "row_exclusion_policy"
          ]
        },
        "question": { "type": "string" },
        "candidate_options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "selected_option": { "type": ["string", "null"] },
        "rationale": { "type": ["string", "null"] },
        "evidence_reference": { "type": "string" },
        "decision_status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "not_applicable"]
        },
        "decided_by": { "type": ["string", "null"] },
        "decided_at": { "type": ["string", "null"] }
      }
    },
    "uom_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_name",
        "raw_uom",
        "normalized_token",
        "occurrence_count",
        "classification",
        "candidate_normalized_uom",
        "selected_normalized_uom",
        "decision_status",
        "rationale",
        "decided_by",
        "decided_at"
      ],
      "properties": {
        "profile_name": { "type": "string" },
        "raw_uom": { "type": "string" },
        "normalized_token": { "type": "string" },
        "occurrence_count": { "type": "integer", "minimum": 0 },
        "classification": {
          "type": "string",
          "enum": [
            "direct_lexical_synonym",
            "packaging_unit",
            "packaging_expression",
            "dimensional_unit",
            "ambiguous_unit",
            "missing_value",
            "invalid_value",
            "not_a_uom"
          ]
        },
        "candidate_normalized_uom": { "type": ["string", "null"] },
        "selected_normalized_uom": { "type": ["string", "null"] },
        "decision_status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "not_applicable"]
        },
        "rationale": { "type": ["string", "null"] },
        "decided_by": { "type": ["string", "null"] },
        "decided_at": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "classification": { "const": "ambiguous_unit" },
              "decision_status": { "const": "approved" }
            },
            "required": ["classification", "decision_status"]
          },
          "then": {
            "properties": {
              "selected_normalized_uom": { "type": "string", "minLength": 1 },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    }
  }
}
