# Supabase
SUPABASE_URL=https://your-project.supabase.co
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
# Local alias accepted by the TAM module; prefer DATABASE_URL in deployed environments.
DB_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Salesforce OAuth2
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=your-connected-app-client-id
SF_CLIENT_SECRET=your-connected-app-client-secret
SF_USERNAME=your-sf-username
SF_PASSWORD=your-sf-password
SF_SECURITY_TOKEN=your-sf-security-token

# Fishbowl Inventory REST API
FISHBOWL_API_URL=http://your-fishbowl-server:port
FISHBOWL_USERNAME=api-user
FISHBOWL_PASSWORD=api-password

# Cloudflare Access (required when Fishbowl is behind a CF Tunnel)
# When set, FISHBOWL_API_URL must be HTTPS without an explicit origin port
# (for example, https://fishbowl.medshipment.com). Leave blank for local dev without tunnel.
FISHBOWL_CF_ACCESS_CLIENT_ID=
FISHBOWL_CF_ACCESS_CLIENT_SECRET=

# Fishbowl Sales Order sync (P7)
FISHBOWL_SO_PAGE_SIZE=100
# Rotating page checkpoints processed per incremental run. With the default 5,
# P7 scans 10 pages per run because legacy config represented pages per edge.
FISHBOWL_SO_INCREMENTAL_PAGES=5
FISHBOWL_SO_PAGE_BATCH=10
FISHBOWL_SO_DETAIL_BATCH=250
FISHBOWL_SO_MAX_ATTEMPTS=3
# Set to 0 to disable Fishbowl-ID discovery. Default scans 250 ids per run.
FISHBOWL_SO_ID_DISCOVERY_BATCH=250
FISHBOWL_SO_FRESHNESS_MAX_DAYS=30
FISHBOWL_SO_STALE_ALERT_COOLDOWN_MINUTES=360

# Hercules API (P10 supplier catalog ingestion, egress-only application)
# App ID is safe to log; the access token is shown once at creation — store
# it in the vault. Tokens expire after ~1 month; coordinate rotation with
# the Hercules admin.
# Backend service host (the hercules-dev host serves only the frontend UI).
HERCULES_API_BASE_URL=https://hercules-sv-dev.medicalshipment.com
HERCULES_API_APP_ID=
HERCULES_API_ACCESS_TOKEN=
HERCULES_API_TIMEOUT_MS=30000
# Egress page size (Hercules max 500) and work budget per Inngest step/run.
HERCULES_INGEST_PAGE_SIZE=500
HERCULES_INGEST_PAGES_PER_STEP=5
HERCULES_INGEST_MAX_STEPS_PER_RUN=40
# Pause ingestion when X-RateLimit-Remaining drops to this value.
HERCULES_INGEST_LOW_RATE_LIMIT_THRESHOLD=10

# Alert delivery for loud sync failures. Configure one path in Railway.
ALERT_WEBHOOK_URL=
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_RECIPIENTS=dan@medicalshipment.com,steven@fullbarsmedia.com

# QuickBooks (leave blank until P3)
QB_ENVIRONMENT=sandbox
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REALM_ID=

# EasyPost (leave blank until P4 Path B)
EASYPOST_API_KEY=

# Inngest
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key

# Email (Resend) — auth emails, invites, alerts.
# Send from a Resend-verified domain you control (not medicalshipment.com).
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Prometheus <no-reply@yourdomain.com>
# Optional legacy alert webhook (falls back to Resend if unset)
ALERT_WEBHOOK_URL=

# Email 2FA — leave off until RESEND_API_KEY + EMAIL_FROM are configured and
# verified, then set to "true" to enforce email codes at login.
TWO_FACTOR_ENABLED=false
# Defaults to SUPABASE_SERVICE_ROLE_KEY if unset; set an independent secret in prod.
TWO_FACTOR_SECRET=

# Mapbox (free tier — 50k map loads/month)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Q3 incentive new-account bell: Slack (or Teams) incoming-webhook URL.
# Unset = falls back to sendAlertEmail (ALERT_WEBHOOK_URL / Resend).
INCENTIVE_BELL_WEBHOOK_URL=

# Commission model explainer (Claude Haiku via OpenRouter; omitted = deterministic fallback text)
OPENROUTER_API_KEY=
