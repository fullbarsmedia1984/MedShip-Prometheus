<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Deterministic sales gamification events generated from Opportunity changes.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>true</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <label>MedShip Game Event</label>
    <nameField>
        <displayFormat>MGE-{000000}</displayFormat>
        <label>Game Event Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>MedShip Game Events</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>

